{
  "name": "pop-motion-reel",
  "version": "1.0.0",
  "private": true,
  "description": "POP MOTION REEL — 30s kinetic motion reel managed as a Remotion video project.",
  "scripts": {
    "start": "remotion studio",
    "studio": "remotion studio",
    "build": "remotion render PopMotionReel out/pop-motion-reel.mp4",
    "render": "remotion render PopMotionReel out/pop-motion-reel.mp4",
    "still": "remotion still PopMotionReel out/thumbnail.png --frame=120",
    "upgrade": "remotion upgrade",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@remotion/cli": "4.0.286",
    "@remotion/google-fonts": "4.0.286",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "remotion": "4.0.286"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "typescript": "^5.4.3"
  }
}
